{
  "type": "module",
  "version": "2.0.2",
  "name": "a-js-tools",
  "private": true,
  "scripts": {
    "b": "rollup --config rollup.config.js && tsc -p tsconfig.types.json",
    "clean:package": "node scripts/clean-package-json.js",
    "build": "jja rm dist && pnpm run b && pnpm run clean:package",
    "build:local": "jja rm dist && node scripts/build-local.js",
    "clean": "jja tm node_modules package-lock.json pnpm-lock.yaml && pnpm install && pnpm run build",
    "dev": "jja rm .eg && rollup --config rollup.dev.config.js && node .eg/index.mjs",
    "diff": "jja pkg --diff=淘宝",
    "lint": "jja cls && eslint src",
    "beautify": "pnpm run prettier",
    "prettier": "jja cls && prettier . --write",
    "push:version": "gvv",
    "push": "gvv",
    "vjj": "vjj -b",
    "prepublishOnly": "pjj",
    "prepare": "husky"
  },
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@qqi/check-version": "^1.1.0",
    "@qqi/copy-text": "^1.1.0",
    "@qqi/dev": "^1.0.0",
    "@qqi/rollup-external": "^1.1.2",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/expect": "^24.3.2",
    "@types/node": "^25.5.0",
    "a-node-tools": "^4.4.2",
    "color-pen": "^3.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.8.0",
    "expect": "^30.3.0",
    "globals": "^17.4.0",
    "gvv": "^1.0.0",
    "husky": "^9.1.7",
    "jja": "^2.4.0",
    "lint-staged": "^16.4.0",
    "pjj": "^1.0.5",
    "prettier": "^3.8.1",
    "rollup": "^4.60.0",
    "rollup-plugin-cleanup": "^3.2.1",
    "rollup-plugin-copy": "^3.5.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vjj": "^1.0.12"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,md,mdx,json}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "a-type-of-js": "^2.0.1"
  }
}
